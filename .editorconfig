root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{cc,cpp,h,hpp}]
indent_style = space
indent_size = 2

[*.{cmake,txt}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf

[*.rc]
end_of_line = crlf
