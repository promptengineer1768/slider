# Build output
build/
dist/
!scripts/build/
!scripts/build/**

# Debug/temporary files (keep directory, ignore contents)
debug/*
!debug/.gitkeep

# IDE files
.vs/
.vscode/
.idea/
*.user
*.suo
*.db
*.opendb

# OS files
.DS_Store
Thumbs.db
*~
*.temp
*.bak

# vcpkg local installs
vcpkg_installed/

# CPack output
_CPack_Packages/

# tools/local binaries (scripts tracked, downloads ignored)
tools/local/*.exe
tools/local/act/
!tools/local/.gitkeep
